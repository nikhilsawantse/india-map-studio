{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nikhilsawantse.github.io/india-map-studio/data/boundary-contribution.schema.json",
  "title": "India Map Studio boundary contribution",
  "description": "Metadata and validation contract for a contributed boundary asset.",
  "type": "object",
  "required": ["schemaVersion", "layer", "source", "processing"],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^1\\." },
    "layer": {
      "type": "object",
      "required": [
        "id",
        "label",
        "level",
        "parentId",
        "file",
        "format",
        "featureCount",
        "featureSelector",
        "identifiers"
      ],
      "properties": {
        "id": { "type": "string", "pattern": "^IN-[A-Z0-9]+(?:-[A-Z0-9]+)*$" },
        "label": { "type": "string", "minLength": 1 },
        "level": {
          "enum": [
            "regions",
            "divisions",
            "districts",
            "subdivisions",
            "tehsils",
            "blocks",
            "villages",
            "gram-panchayats",
            "wards",
            "other"
          ]
        },
        "parentId": {
          "type": ["string", "null"],
          "pattern": "^IN-[A-Z0-9]+(?:-[A-Z0-9]+)*$"
        },
        "file": { "type": "string", "pattern": "^[^/\\\\].*\\.(?:svg|geojson|json)$" },
        "format": { "enum": ["svg", "geojson"] },
        "featureCount": { "type": "integer", "minimum": 1 },
        "featureSelector": { "type": "string", "minLength": 1 },
        "identifiers": {
          "type": "object",
          "required": ["feature", "slug"],
          "properties": {
            "feature": { "type": "string", "minLength": 1 },
            "slug": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "required": [
        "name",
        "url",
        "revision",
        "retrievedAt",
        "vintage",
        "license",
        "attribution",
        "redistributionConfirmed"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "format": "uri" },
        "revision": { "type": "string", "minLength": 1 },
        "retrievedAt": { "type": "string", "format": "date" },
        "vintage": { "type": "string", "minLength": 1 },
        "license": {
          "type": "object",
          "required": ["name", "spdx", "url"],
          "properties": {
            "name": { "type": "string", "minLength": 1 },
            "spdx": { "type": "string", "minLength": 1 },
            "url": { "type": "string", "format": "uri" }
          },
          "additionalProperties": false
        },
        "attribution": { "type": "string", "minLength": 1 },
        "redistributionConfirmed": { "const": true }
      },
      "additionalProperties": false
    },
    "processing": {
      "type": "object",
      "required": ["transformations", "command"],
      "properties": {
        "transformations": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "command": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
